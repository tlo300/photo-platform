# ── PostgreSQL ──────────────────────────────────────────────────────────────
# Superuser (used only by Docker to initialise the database)
POSTGRES_DB=photo
POSTGRES_SUPERUSER=superuser
POSTGRES_SUPERUSER_PASSWORD=changeme

# app_user — low-privilege, RLS enforced (used by FastAPI at runtime)
DATABASE_APP_USER=app_user
DATABASE_APP_PASSWORD=changeme
DATABASE_URL=postgresql+asyncpg://app_user:changeme@db:5432/photo

# migrator — schema-level access (used by Alembic only)
DATABASE_MIGRATOR_USER=migrator
DATABASE_MIGRATOR_PASSWORD=changeme
DATABASE_MIGRATOR_URL=postgresql://migrator:changeme@db:5432/photo

# ── MinIO / S3-compatible object storage ────────────────────────────────────
# Root credentials — used to provision the bucket on first start
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=changeme

# Application credentials — must match MINIO_ROOT_USER / MINIO_ROOT_PASSWORD above
STORAGE_ENDPOINT=minio:9000
STORAGE_ACCESS_KEY=minioadmin
STORAGE_SECRET_KEY=changeme
STORAGE_BUCKET=photos
STORAGE_USE_SSL=false

# ── Redis ───────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── Auth ────────────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=changeme-use-a-long-random-string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Application ─────────────────────────────────────────────────────────────
ALLOW_OPEN_REGISTRATION=false
MAX_UPLOAD_SIZE_BYTES=5368709120

# ── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost

# ── Frontend ────────────────────────────────────────────────────────────────
# Server-side URL (used by Next.js server components inside Docker)
API_URL=http://backend:8000
# Browser-facing URL (goes through Caddy)
NEXT_PUBLIC_API_URL=http://localhost/api
